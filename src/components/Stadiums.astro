---
---
<section x-show="currentTab === 'stadiums'" class="glass-panel" style="animation: fadeIn 0.4s ease-out;">
  <div style="display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 20px; margin-bottom: 30px;">
    <div>
      <h1 style="font-size: 2.2rem; background: linear-gradient(135deg, #ffffff 0%, rgba(255,255,255,0.7) 100%); -webkit-background-clip: text; -webkit-text-fill-color: transparent;">
        Host Cities & Stadiums
      </h1>
      <p style="color: var(--text-muted); margin-top: 4px;">Tour the 16 historic venues hosting the 2026 World Cup across Canada, Mexico, and the USA.</p>
    </div>

    <!-- Country Filters -->
    <div style="display: flex; background: rgba(0, 0, 0, 0.2); border-radius: var(--radius-sm); padding: 4px; border: 1px solid rgba(var(--primary-rgb), 0.1);">
      <template x-for="country in ['All', 'USA', 'Canada', 'Mexico']">
        <button 
          @click="stadiumCountryFilter = country" 
          x-text="country"
          class="btn btn-secondary"
          style="padding: 6px 12px; font-size: 0.75rem; border: none; background: transparent;"
          :style="stadiumCountryFilter === country ? 'background: var(--primary) !important; color: #0b0f19; font-weight:700; border-radius: var(--radius-sm);' : ''"
        ></button>
      </template>
    </div>
  </div>

  <!-- Stadiums Grid -->
  <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 24px;">
    <template x-for="stadium in stadiums" :key="stadium.id">
      <div 
        x-show="stadiumCountryFilter === 'All' || stadium.country === stadiumCountryFilter"
        class="glass-panel hover-scale" 
        style="padding: 0; overflow: hidden; background: rgba(var(--card-bg-rgb), 0.5); display: flex; flex-direction: column;"
      >
        <!-- Stadium Image with Overlay -->
        <div style="height: 180px; position: relative; overflow: hidden; background: #000;">
          <img 
            :src="stadium.image" 
            :alt="stadium.name" 
            style="width: 100%; height: 100%; object-fit: cover; opacity: 0.75; transition: var(--transition-slow);"
            class="stadium-img"
          />
          <div style="position: absolute; top: 12px; right: 12px;">
            <span class="badge badge-primary" style="font-size: 0.65rem; backdrop-filter: blur(8px); background: rgba(var(--primary-rgb), 0.2);" x-text="'Capacity: ' + stadium.capacity.toLocaleString()"></span>
          </div>
          
          <!-- Flag Overlay -->
          <div style="position: absolute; bottom: 12px; left: 12px; font-size: 1.8rem; filter: drop-shadow(0 2px 4px rgba(0,0,0,0.5));" x-text="getCountryFlag(stadium.country)"></div>
        </div>

        <!-- Details -->
        <div style="padding: 20px; display: flex; flex-direction: column; justify-content: space-between; flex-grow: 1;">
          <div>
            <h3 x-text="stadium.name" style="font-size: 1.15rem; margin-bottom: 6px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;"></h3>
            <p style="color: var(--text-muted); font-size: 0.85rem; display: flex; align-items: center; gap: 6px;">
              <span>📍</span> <span x-text="stadium.city + ', ' + stadium.country"></span>
            </p>
          </div>
          
          <div style="margin-top: 16px; border-top: 1px solid rgba(255,255,255,0.05); padding-top: 12px; display: flex; justify-content: space-between; align-items: center;">
            <span style="font-size: 0.75rem; color: var(--primary); font-weight: 600; text-transform: uppercase; letter-spacing: 0.05em;">View Matches</span>
            <span style="font-size: 0.85rem;">➔</span>
          </div>
        </div>
      </div>
    </template>
  </div>
</section>

<style>
  .glass-panel:hover .stadium-img {
    transform: scale(1.05);
    opacity: 0.9;
  }
  @keyframes fadeIn {
    from { opacity: 0; transform: translateY(10px); }
    to { opacity: 1; transform: translateY(0); }
  }
</style>
