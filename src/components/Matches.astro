---
---
<section x-show="currentTab === 'matches'" class="glass-panel" style="animation: fadeIn 0.4s ease-out;">
  <div style="display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 20px; margin-bottom: 30px;">
    <div>
      <h1 style="font-size: 2.2rem; background: linear-gradient(135deg, #ffffff 0%, rgba(255,255,255,0.7) 100%); -webkit-background-clip: text; -webkit-text-fill-color: transparent;">
        Matches & Schedules
      </h1>
      <p style="color: var(--text-muted); margin-top: 4px;" x-text="config.eventInfo?.description"></p>
    </div>

    <!-- Search and Filters -->
    <div style="display: flex; gap: 12px; align-items: center; flex-wrap: wrap;">
      <input 
        type="text" 
        x-model="matchSearch" 
        placeholder="🔍 Search teams, cities..." 
        class="form-input" 
        style="width: 240px; margin: 0;"
      />
      
      <div style="display: flex; background: rgba(0, 0, 0, 0.2); border-radius: var(--radius-sm); padding: 4px; border: 1px solid rgba(var(--primary-rgb), 0.1);">
        <template x-for="filter in ['All', 'Live', 'Scheduled', 'Finished']">
          <button 
            @click="matchFilter = filter" 
            x-text="filter"
            class="btn btn-secondary"
            style="padding: 6px 12px; font-size: 0.75rem; border: none; background: transparent;"
            :style="matchFilter === filter ? 'background: var(--primary) !important; color: #0b0f19; font-weight:700; border-radius: var(--radius-sm);' : ''"
          ></button>
        </template>
      </div>
    </div>
  </div>

  <!-- Match Grid -->
  <div style="display: flex; flex-direction: column; gap: 16px;">
    <!-- Empty State -->
    <div x-show="matches.filter(m => (matchFilter === 'All' || m.status === matchFilter) && (matchSearch === '' || (typeof m.homeTeam === 'object' && m.homeTeam.name.toLowerCase().includes(matchSearch.toLowerCase())) || (typeof m.awayTeam === 'object' && m.awayTeam.name.toLowerCase().includes(matchSearch.toLowerCase())) || m.stage.toLowerCase().includes(matchSearch.toLowerCase()) || m.stadiumId.toLowerCase().includes(matchSearch.toLowerCase()))).length === 0" style="text-align: center; padding: 40px; background: rgba(var(--card-bg-rgb), 0.3); border-radius: 12px; border: 1px dashed rgba(255,255,255,0.1);">
      <div style="font-size: 3rem; margin-bottom: 10px;">⚽</div>
      <h3 style="color: #ffffff; margin-bottom: 8px;">No matches found</h3>
      <p style="color: var(--text-muted); font-size: 0.9rem;">
        There are currently no <strong x-text="matchFilter"></strong> matches that match your criteria.
      </p>
    </div>
    <template x-for="match in matches" :key="match.id">
      <div 
        x-show="
          (matchFilter === 'All' || match.status === matchFilter) &&
          (matchSearch === '' || 
           (typeof match.homeTeam === 'object' && match.homeTeam.name.toLowerCase().includes(matchSearch.toLowerCase())) ||
           (typeof match.awayTeam === 'object' && match.awayTeam.name.toLowerCase().includes(matchSearch.toLowerCase())) ||
           match.stage.toLowerCase().includes(matchSearch.toLowerCase()) ||
           match.stadiumId.toLowerCase().includes(matchSearch.toLowerCase()))
        "
        class="glass-panel hover-scale" 
        style="padding: 20px; display: grid; grid-template-columns: 1fr auto 1fr; align-items: center; gap: 20px; background: rgba(var(--card-bg-rgb), 0.5); border-left: 4px solid;"
        :style="
          match.status === 'Live' ? 'border-color: #ef4444; background: rgba(239, 68, 68, 0.05);' :
          match.status === 'Finished' ? 'border-color: rgba(255,255,255,0.2);' : 'border-color: var(--primary);'
        "
      >
        <!-- Home Team -->
        <div style="display: flex; flex-direction: column; align-items: flex-end; gap: 4px;">
          <span style="font-size: 0.65rem; color: var(--text-muted); text-transform: uppercase; font-weight: 700; letter-spacing: 1px;">Home</span>
          <div style="display: flex; align-items: center; justify-content: flex-end; gap: 16px;">
            <span style="font-size: 1.2rem; font-weight: 600; text-align: right;" x-text="typeof match.homeTeam === 'object' ? match.homeTeam.name : match.homeTeam"></span>
            <span style="font-size: 2.2rem; filter: drop-shadow(0 2px 4px rgba(0,0,0,0.3));" x-text="typeof match.homeTeam === 'object' ? match.homeTeam.flag : '🏳️'"></span>
          </div>
        </div>

        <!-- Score / Time Middle Block -->
        <div style="display: flex; flex-direction: column; align-items: center; min-width: 140px;">
          <span class="badge" 
            :class="
              match.status === 'Live' ? 'badge-accent' :
              match.status === 'Finished' ? 'badge-primary' : 'badge-primary'
            "
            style="font-size: 0.65rem; margin-bottom: 8px;"
          >
            <span x-show="match.status === 'Live'" style="display: inline-block; width: 6px; height: 6px; border-radius: 50%; background: #ef4444; margin-right: 6px; animation: pulse-dot 1.5s infinite;"></span>
            <span x-text="match.status"></span>
          </span>

          <!-- Scores or Schedule Time -->
          <div style="font-size: 2.2rem; font-weight: 900; font-family: var(--font-heading); display: flex; align-items: center; gap: 20px; background: rgba(0,0,0,0.2); padding: 8px 24px; border-radius: 8px; border: 1px solid rgba(255,255,255,0.05);">
            <template x-if="match.status === 'Live' || match.status === 'Finished'">
              <div style="display: flex; align-items: center; gap: 16px;">
                <!-- Home Team Badge & Score -->
                <div style="display: flex; align-items: center; gap: 10px;">
                  <span style="font-size: 1.2rem; filter: drop-shadow(0 2px 4px rgba(0,0,0,0.3));" x-text="typeof match.homeTeam === 'object' ? match.homeTeam.flag : '🏳️'"></span>
                  <span style="font-size: 1.1rem; font-weight: 700; color: rgba(255,255,255,0.6);" x-text="typeof match.homeTeam === 'object' ? match.homeTeam.code : 'Home'"></span>
                  <span x-text="match.homeScore" style="color: #ffffff; margin-left: 6px;">0</span>
                </div>
                
                <span style="font-size: 1.2rem; color: rgba(255,255,255,0.2);">-</span>
                
                <!-- Away Team Badge & Score -->
                <div style="display: flex; align-items: center; gap: 10px;">
                  <span x-text="match.awayScore" style="color: #ffffff; margin-right: 6px;">0</span>
                  <span style="font-size: 1.1rem; font-weight: 700; color: rgba(255,255,255,0.6);" x-text="typeof match.awayTeam === 'object' ? match.awayTeam.code : 'Away'"></span>
                  <span style="font-size: 1.2rem; filter: drop-shadow(0 2px 4px rgba(0,0,0,0.3));" x-text="typeof match.awayTeam === 'object' ? match.awayTeam.flag : '🏳️'"></span>
                </div>
              </div>
            </template>
            <template x-if="match.status === 'Scheduled'">
              <span style="font-size: 1.1rem; color: var(--primary); font-weight: 600;" x-text="match.time"></span>
            </template>
          </div>

          <span style="font-size: 0.75rem; color: var(--text-muted); margin-top: 8px;" x-text="match.date"></span>
        </div>

        <!-- Away Team -->
        <div style="display: flex; flex-direction: column; align-items: flex-start; gap: 4px;">
          <span style="font-size: 0.65rem; color: var(--text-muted); text-transform: uppercase; font-weight: 700; letter-spacing: 1px;">Away</span>
          <div style="display: flex; align-items: center; justify-content: flex-start; gap: 16px;">
            <span style="font-size: 2.2rem; filter: drop-shadow(0 2px 4px rgba(0,0,0,0.3));" x-text="typeof match.awayTeam === 'object' ? match.awayTeam.flag : '🏳️'"></span>
            <span style="font-size: 1.2rem; font-weight: 600;" x-text="typeof match.awayTeam === 'object' ? match.awayTeam.name : match.awayTeam"></span>
          </div>
        </div>

        <!-- Details Footer & Prediction Panel (span columns 3) -->
        <div style="grid-column: span 3; display: flex; justify-content: space-between; align-items: center; border-top: 1px solid rgba(255,255,255,0.05); padding-top: 12px; margin-top: 8px; flex-wrap: wrap; gap: 10px;">
          <div style="display: flex; gap: 12px; font-size: 0.8rem; color: var(--text-muted);">
            <span>📍 Stadium: <strong style="color: #ffffff;" x-text="stadiums.find(s => s.id === match.stadiumId || s.stadiumId === match.stadiumId)?.name || match.stadiumId"></strong></span>
            <span>🏷️ Stage: <strong style="color: #ffffff;" x-text="match.stage"></strong></span>
          </div>

          <!-- Prediction Interface (Conditional on Feature Flag) -->
          <template x-if="config.features?.enablePredictions && match.status === 'Scheduled'">
            <div style="display: flex; align-items: center; gap: 8px;">
              <span style="font-size: 0.75rem; color: var(--text-muted); font-weight: 600;">PREDICT:</span>
              <div style="display: flex; background: rgba(0, 0, 0, 0.2); border-radius: 6px; padding: 2px;">
                <button 
                  @click="makePrediction(match.id, 'home')" 
                  class="btn btn-secondary" 
                  style="padding: 4px 10px; font-size: 0.7rem; border: none;"
                  :style="predictions[match.id] === 'home' ? 'background: var(--primary) !important; color: #0b0f19; border-radius: 4px;' : ''"
                  x-text="typeof match.homeTeam === 'object' ? match.homeTeam.code : 'Home'"
                ></button>
                <button 
                  @click="makePrediction(match.id, 'draw')" 
                  class="btn btn-secondary" 
                  style="padding: 4px 10px; font-size: 0.7rem; border: none;"
                  :style="predictions[match.id] === 'draw' ? 'background: var(--accent) !important; color: #ffffff; border-radius: 4px;' : ''"
                >DRAW</button>
                <button 
                  @click="makePrediction(match.id, 'away')" 
                  class="btn btn-secondary" 
                  style="padding: 4px 10px; font-size: 0.7rem; border: none;"
                  :style="predictions[match.id] === 'away' ? 'background: var(--primary) !important; color: #0b0f19; border-radius: 4px;' : ''"
                  x-text="typeof match.awayTeam === 'object' ? match.awayTeam.code : 'Away'"
                ></button>
              </div>
            </div>
          </template>
        </div>
      </div>
    </template>
  </div>
</section>

<style>
  @keyframes fadeIn {
    from { opacity: 0; transform: translateY(10px); }
    to { opacity: 1; transform: translateY(0); }
  }
  @keyframes pulse-dot {
    0%, 100% { opacity: 1; transform: scale(1); }
    50% { opacity: 0.4; transform: scale(1.2); }
  }
</style>
