---
import '../styles/global.css';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="generator" content={Astro.generator} />
    <title>World Cup 2026 Tracker</title>
    <!-- Leaflet.js Geolocation Map CDN -->
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY=" crossorigin="" />
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js" integrity="sha256-20nQCchB9co0qIjJZRGuk2/Z9VM+kNiyxNV1lvTlZBo=" crossorigin=""></script>
  </head>
  <body>
    <!-- Background Gradient Glows -->
    <div class="bg-gradient-glow"></div>

    <!-- Alpine.js Application Shell -->
    <div 
      x-data="worldCupApp" 
      x-init="initApp()" 
      class="app-container"
      x-cloak
    >
      <!-- Sidebar Navigation -->
      <aside class="glass-panel" style="margin: 20px; height: calc(100vh - 40px); display: flex; flex-direction: column; justify-content: space-between; border-radius: var(--radius-lg);">
        <div>
          <!-- Tenant / Branding Header -->
          <div style="padding: 10px 0 20px 0; border-bottom: 1px solid rgba(var(--primary-rgb), 0.2);">
            <div style="display: flex; align-items: center; gap: 10px;">
              <span style="font-size: 2rem; animation: pulse 2s infinite;">🏆</span>
              <div>
                <h2 x-text="config.appName || 'World Cup 2026'" style="font-size: 1.2rem; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; color: var(--primary);">Loading...</h2>
                <div style="display: flex; align-items: center; gap: 6px; margin-top: 4px;">
                  <span class="badge badge-primary" style="font-size: 0.6rem; padding: 2px 6px;" x-text="config.tenantId || 'default'"></span>
                  <template x-if="config.pocketbaseUrl">
                    <span class="badge badge-success" style="font-size: 0.6rem; padding: 2px 6px;">PB</span>
                  </template>
                </div>
              </div>
            </div>
          </div>

          <!-- Navigation Links -->
          <nav style="margin-top: 30px; display: flex; flex-direction: column; gap: 10px;">
            <button 
              @click="currentTab = 'matches'" 
              class="btn"
              :class="currentTab === 'matches' ? '' : 'btn-secondary'"
              style="width: 100%; justify-content: flex-start;"
            >
              ⚽ Matches & Scores
            </button>
            
            <button 
              @click="currentTab = 'standings'" 
              class="btn"
              :class="currentTab === 'standings' ? '' : 'btn-secondary'"
              style="width: 100%; justify-content: flex-start;"
            >
              📊 Groups & Standings
            </button>

            <button 
              @click="currentTab = 'map'" 
              class="btn"
              :class="currentTab === 'map' ? '' : 'btn-secondary'"
              style="width: 100%; justify-content: flex-start;"
            >
              🗺️ Interactive Map
            </button>
            
            <template x-if="config.features?.enableStadiumGuide">
              <button 
                @click="currentTab = 'stadiums'" 
                class="btn"
                :class="currentTab === 'stadiums' ? '' : 'btn-secondary'"
                style="width: 100%; justify-content: flex-start;"
              >
                🏟️ Stadiums & Cities
              </button>
            </template>

            <button 
              @click="currentTab = 'config'" 
              class="btn"
              :class="currentTab === 'config' ? '' : 'btn-secondary'"
              style="width: 100%; justify-content: flex-start; margin-top: 20px; border: 1px dashed rgba(var(--primary-rgb), 0.4);"
            >
              ⚙️ 12-Factor Config
            </button>
          </nav>
        </div>

        <!-- Footer / System Info -->
        <div style="border-top: 1px solid rgba(255, 255, 255, 0.05); padding-top: 15px;">
          <p style="font-size: 0.75rem; color: var(--text-muted);">
            Running on <strong style="color: #ffffff;">Bun + Tauri v2</strong>
          </p>
          <p style="font-size: 0.7rem; color: var(--text-muted); margin-top: 4px; display: flex; align-items: center; gap: 4px;">
            <span style="display: inline-block; width: 6px; height: 6px; border-radius: 50%;" :style="isTauri ? 'background-color: #10b981' : 'background-color: #f59e0b'"></span>
            <span x-text="isTauri ? 'Desktop/Mobile Shell' : 'Web App Mode'"></span>
          </p>
        </div>
      </aside>

      <!-- Main Content Area -->
      <main class="main-content">
        <slot />
      </main>
    </div>

    <!-- Alpine.js App State Script -->
    <script>
      import Alpine from 'alpinejs';
      import PocketBase from 'pocketbase';
      import { loadTenantConfig, applyTheme, isTauriEnvironment, MOCK_DB_TENANTS } from '../lib/config';
      import { STADIUMS, MATCHES, GROUP_STANDINGS, TEAMS, type Match, type Stadium, type GroupStanding, type Team } from '../lib/mockData';

      // Define Alpine Component State
      Alpine.data('worldCupApp', () => ({
        currentTab: 'matches',
        config: {} as any,
        isTauri: false,
        stadiums: [] as Stadium[],
        matches: [] as Match[],
        standings: [] as GroupStanding[],
        teams: [] as Team[],
        pb: null as any,
        
        // Match filtering and search
        matchSearch: '',
        matchFilter: 'All', // 'All', 'Live', 'Scheduled', 'Finished'
        
        // Stadium filtering
        stadiumCountryFilter: 'All', // 'All', 'USA', 'Canada', 'Mexico'
        
        // Predictions State
        predictions: {} as Record<string, 'home' | 'draw' | 'away'>,
        
        // Configuration editor fields (for demonstration & runtime config settings)
        pbUrlInput: '',
        tenantInput: 'world-cup-classic',
        availableTenants: Object.keys(MOCK_DB_TENANTS),
        
        async initApp() {
          this.isTauri = isTauriEnvironment();
          this.stadiums = STADIUMS;
          this.matches = MATCHES;
          this.standings = GROUP_STANDINGS;
          this.teams = TEAMS;
          
          // Load stored predictions
          const savedPreds = localStorage.getItem('wc_predictions');
          if (savedPreds) {
            this.predictions = JSON.parse(savedPreds);
          }

          // Load dynamic tenant configuration
          await this.reloadConfig();
        },

        async reloadConfig() {
          // Resolve config
          const config = await loadTenantConfig();
          this.config = config;
          
          // Set inputs to current values
          this.pbUrlInput = config.pocketbaseUrl || '';
          this.tenantInput = config.tenantId;
          
          // Apply styling dynamically
          applyTheme(config);

          // Setup real-time PocketBase integration
          await this.setupPocketBaseData();
        },

        async setupPocketBaseData() {
          // Clean up existing subscriptions if active
          if (this.pb) {
            try {
              await this.pb.collection('matches').unsubscribe();
              await this.pb.collection('standings').unsubscribe();
              await this.pb.collection('group_standings').unsubscribe();
              await this.pb.collection('stadiums').unsubscribe();
              await this.pb.collection('teams').unsubscribe();
            } catch (err) {
              console.warn('Error unsubscribing:', err);
            }
            this.pb = null;
          }

          if (!this.config.pocketbaseUrl) {
            this.stadiums = STADIUMS;
            this.matches = MATCHES;
            this.standings = GROUP_STANDINGS;
            this.teams = TEAMS;
            return;
          }

          try {
            this.pb = new PocketBase(this.config.pocketbaseUrl);

            // Fetch initial real-time data from PocketBase
            await this.fetchPocketBaseData();

            // Subscribe to real-time updates for Matches
            try {
              await this.pb.collection('matches').subscribe('*', (e: any) => {
                this.handleMatchRealtimeUpdate(e);
              });
            } catch (err) {
              console.warn('Matches subscription failed:', err);
            }

            // Subscribe to real-time updates for Teams
            try {
              await this.pb.collection('teams').subscribe('*', (e: any) => {
                this.handleTeamRealtimeUpdate(e);
              });
            } catch (err) {
              console.warn('Teams subscription failed:', err);
            }

            // Subscribe to real-time updates for Standings
            try {
              await this.pb.collection('standings').subscribe('*', (e: any) => {
                this.handleStandingRealtimeUpdate(e);
              });
            } catch (err) {
              try {
                await this.pb.collection('group_standings').subscribe('*', (e: any) => {
                  this.handleStandingRealtimeUpdate(e);
                });
              } catch (err2) {
                console.warn('Standings subscription failed:', err2);
              }
            }

            // Subscribe to real-time updates for Stadiums
            try {
              await this.pb.collection('stadiums').subscribe('*', (e: any) => {
                this.handleStadiumRealtimeUpdate(e);
              });
            } catch (err) {
              console.warn('Stadiums subscription failed:', err);
            }

            console.log('PocketBase real-time subscriptions established successfully.');
          } catch (err) {
            console.error('Failed to configure PocketBase connection. Falling back to local data.', err);
            this.stadiums = STADIUMS;
            this.matches = MATCHES;
            this.standings = GROUP_STANDINGS;
            this.teams = TEAMS;
          }
        },

        async fetchPocketBaseData() {
          if (!this.pb) return;

          // Fetch Teams first so they are available for match and standing resolving
          try {
            const pbTeams = await this.pb.collection('teams').getFullList();
            if (pbTeams && pbTeams.length > 0) {
              this.teams = pbTeams.map((t: any) => ({
                id: t.id,
                teamId: t.teamId || t.id,
                name: t.name,
                code: t.code,
                flag: t.flag || '🏳️',
                group: t.group || ''
              }));
            }
          } catch (err) {
            console.warn('Failed to load teams from PocketBase, using static data.', err);
            this.teams = TEAMS;
          }

          // Fetch Stadiums
          try {
            const pbStadiums = await this.pb.collection('stadiums').getFullList();
            if (pbStadiums && pbStadiums.length > 0) {
              this.stadiums = pbStadiums.map((s: any) => ({
                id: s.id,
                stadiumId: s.stadiumId || s.id,
                name: s.name,
                city: s.city,
                country: s.country,
                capacity: Number(s.capacity || 0),
                image: s.image || 'https://images.unsplash.com/photo-1508098682722-e99c43a406b2?w=500&auto=format&fit=crop&q=60',
                lat: Number(s.lat || 0),
                lng: Number(s.lng || 0),
                info: s.info || ''
              }));
            }
          } catch (err) {
            console.warn('Failed to load stadiums from PocketBase, using static data.', err);
            this.stadiums = STADIUMS;
          }

          // Fetch Matches
          try {
            const pbMatches = await this.pb.collection('matches').getFullList({
              sort: 'date,time',
              expand: 'homeTeam,awayTeam,stadiumId,stadium'
            });
            if (pbMatches && pbMatches.length > 0) {
              this.matches = pbMatches.map((m: any) => this.resolveMatchRecord(m));
            }
          } catch (err) {
            console.warn('Failed to load matches from PocketBase, using static data.', err);
            this.matches = MATCHES;
          }

          // Fetch Standings
          await this.fetchStandingsOnly();
        },

        async fetchStandingsOnly() {
          if (!this.pb) return;
          try {
            let pbStandings = [];
            try {
              pbStandings = await this.pb.collection('standings').getFullList({
                expand: 'teamId,team'
              });
            } catch (err) {
              pbStandings = await this.pb.collection('group_standings').getFullList({
                expand: 'teamId,team'
              });
            }
            if (pbStandings && pbStandings.length > 0) {
              this.standings = this.processStandings(pbStandings);
            } else {
              this.standings = GROUP_STANDINGS;
            }
          } catch (err) {
            console.warn('Failed to load standings from PocketBase, using static data.', err);
            this.standings = GROUP_STANDINGS;
          }
        },

        resolveTeam(teamInput: any) {
          if (typeof teamInput === 'object' && teamInput !== null) {
            const teamId = teamInput.id || teamInput.teamId;
            const found = this.teams.find(t => t.id === teamId || t.teamId === teamId);
            if (found) return found;
            return {
              id: teamId || 'unknown',
              name: teamInput.name || teamInput.teamName || 'Unknown Team',
              code: teamInput.code || 'UNK',
              flag: teamInput.flag || '🏳️',
              group: teamInput.group || ''
            };
          }
          if (typeof teamInput === 'string') {
            const found = this.teams.find(t => t.id === teamInput || t.teamId === teamInput || t.code === teamInput || t.name === teamInput);
            if (found) return found;
            return {
              id: teamInput,
              name: teamInput,
              code: teamInput.substring(0, 3).toUpperCase(),
              flag: '🏳️',
              group: ''
            };
          }
          return { id: 'unknown', name: 'Unknown Team', code: 'UNK', flag: '🏳️', group: '' };
        },

        resolveMatchRecord(record: any): Match {
          return {
            id: record.matchId || record.id,
            homeTeam: this.resolveTeam(record.expand?.homeTeam || record.homeTeam),
            awayTeam: this.resolveTeam(record.expand?.awayTeam || record.awayTeam),
            homeScore: record.homeScore !== undefined && record.homeScore !== null ? Number(record.homeScore) : undefined,
            awayScore: record.awayScore !== undefined && record.awayScore !== null ? Number(record.awayScore) : undefined,
            date: record.date,
            time: record.time,
            stadiumId: record.expand?.stadiumId?.stadiumId || record.expand?.stadiumId?.id || record.expand?.stadium?.stadiumId || record.expand?.stadium?.id || record.stadiumId || record.stadium,
            stage: record.stage || 'Group Stage',
            status: record.status || 'Scheduled'
          };
        },

        processStandings(records: any[]): GroupStanding[] {
          if (!records || records.length === 0) return GROUP_STANDINGS;

          const firstRecord = records[0];
          const isGroupBased = firstRecord.teams !== undefined;

          if (isGroupBased) {
            return records.map(r => {
              let teams = r.teams;
              if (typeof teams === 'string') {
                try {
                  teams = JSON.parse(teams);
                } catch (e) {
                  teams = [];
                }
              }
              return {
                group: r.group,
                teams: Array.isArray(teams) ? teams.map(t => {
                  const resolved = this.resolveTeam(t);
                  return {
                    teamId: resolved.id,
                    teamName: resolved.name,
                    code: resolved.code,
                    played: Number(t.played ?? 0),
                    won: Number(t.won ?? 0),
                    drawn: Number(t.drawn ?? 0),
                    lost: Number(t.lost ?? 0),
                    goalsFor: Number(t.goalsFor ?? t.goals_for ?? 0),
                    goalsAgainst: Number(t.goalsAgainst ?? t.goals_against ?? 0),
                    points: Number(t.points ?? 0)
                  };
                }) : []
              };
            });
          }

          // Group individual records by `group` field
          const groupsMap: Record<string, any[]> = {};
          records.forEach(r => {
            const groupName = r.group || 'Group A';
            if (!groupsMap[groupName]) {
              groupsMap[groupName] = [];
            }
            const teamObj = r.expand?.teamId || r.expand?.team || {};
            const teamName = r.teamName || r.team_name || r.name || teamObj.name || teamObj.teamName || 'Unknown Team';
            const code = r.code || teamObj.code || (teamName || '').substring(0, 3).toUpperCase();
            groupsMap[groupName].push({
              teamId: r.teamId || r.id,
              teamName: teamName,
              code: code,
              played: Number(r.played ?? 0),
              won: Number(r.won ?? 0),
              drawn: Number(r.drawn ?? 0),
              lost: Number(r.lost ?? 0),
              goalsFor: Number(r.goalsFor ?? r.goals_for ?? 0),
              goalsAgainst: Number(r.goalsAgainst ?? r.goals_against ?? 0),
              points: Number(r.points ?? 0)
            });
          });

          return Object.keys(groupsMap).map(groupName => {
            const sortedTeams = groupsMap[groupName].sort((a, b) => {
              if (b.points !== a.points) return b.points - a.points;
              const gdA = a.goalsFor - a.goalsAgainst;
              const gdB = b.goalsFor - b.goalsAgainst;
              if (gdB !== gdA) return gdB - gdA;
              return b.goalsFor - a.goalsFor;
            });
            return {
              group: groupName,
              teams: sortedTeams
            };
          });
        },

        handleMatchRealtimeUpdate(e: any) {
          console.log('Real-time match update received:', e);
          const resolvedMatch = this.resolveMatchRecord(e.record);
          if (e.action === 'create') {
            if (!this.matches.some(m => m.id === resolvedMatch.id)) {
              this.matches.push(resolvedMatch);
              this.matches.sort((a, b) => (a.date + ' ' + a.time).localeCompare(b.date + ' ' + b.time));
            }
          } else if (e.action === 'update') {
            const idx = this.matches.findIndex(m => m.id === resolvedMatch.id);
            if (idx !== -1) {
              this.matches[idx] = resolvedMatch;
            } else {
              this.matches.push(resolvedMatch);
              this.matches.sort((a, b) => (a.date + ' ' + a.time).localeCompare(b.date + ' ' + b.time));
            }
          } else if (e.action === 'delete') {
            this.matches = this.matches.filter(m => m.id !== resolvedMatch.id);
          }
        },

        handleTeamRealtimeUpdate(e: any) {
          console.log('Real-time team update received:', e);
          const resolvedTeam = {
            id: e.record.id,
            teamId: e.record.teamId || e.record.id,
            name: e.record.name,
            code: e.record.code,
            flag: e.record.flag || '🏳️',
            group: e.record.group || ''
          };

          if (e.action === 'create') {
            if (!this.teams.some(t => t.id === resolvedTeam.id)) {
              this.teams.push(resolvedTeam);
            }
          } else if (e.action === 'update') {
            const idx = this.teams.findIndex(t => t.id === resolvedTeam.id);
            if (idx !== -1) {
              this.teams[idx] = resolvedTeam;
            } else {
              this.teams.push(resolvedTeam);
            }
          } else if (e.action === 'delete') {
            this.teams = this.teams.filter(t => t.id !== resolvedTeam.id);
          }

          // Force re-resolving matches to propagate team changes
          this.matches = this.matches.map(m => {
            return {
              ...m,
              homeTeam: this.resolveTeam(m.homeTeam),
              awayTeam: this.resolveTeam(m.awayTeam)
            };
          });
        },

        handleStandingRealtimeUpdate(e: any) {
          console.log('Real-time standing update received:', e);
          this.fetchStandingsOnly();
        },

        handleStadiumRealtimeUpdate(e: any) {
          console.log('Real-time stadium update received:', e);
          const resolvedStadium = {
            id: e.record.id,
            stadiumId: e.record.stadiumId || e.record.id,
            name: e.record.name,
            city: e.record.city,
            country: e.record.country,
            capacity: Number(e.record.capacity || 0),
            image: e.record.image || 'https://images.unsplash.com/photo-1508098682722-e99c43a406b2?w=500&auto=format&fit=crop&q=60',
            lat: Number(e.record.lat || 0),
            lng: Number(e.record.lng || 0),
            info: e.record.info || ''
          };

          if (e.action === 'create') {
            if (!this.stadiums.some(s => s.id === resolvedStadium.id)) {
              this.stadiums.push(resolvedStadium);
            }
          } else if (e.action === 'update') {
            const idx = this.stadiums.findIndex(s => s.id === resolvedStadium.id);
            if (idx !== -1) {
              this.stadiums[idx] = resolvedStadium;
            } else {
              this.stadiums.push(resolvedStadium);
            }
          } else if (e.action === 'delete') {
            this.stadiums = this.stadiums.filter(s => s.id !== resolvedStadium.id);
          }
        },

        // Helper to format country code to flag
        getCountryFlag(country: string): string {
          switch (country) {
            case 'USA': return '🇺🇸';
            case 'Canada': return '🇨🇦';
            case 'Mexico': return '🇲🇽';
            default: return '🏳️';
          }
        },

        // Prediction functionality
        makePrediction(matchId: string, outcome: 'home' | 'draw' | 'away') {
          this.predictions[matchId] = outcome;
          localStorage.setItem('wc_predictions', JSON.stringify(this.predictions));
        },

        async saveConfigOverride() {
          // Store overrides in LocalStorage for demonstration/session behavior
          if (this.tenantInput) {
            localStorage.setItem('tenant_id', this.tenantInput);
          } else {
            localStorage.removeItem('tenant_id');
          }

          if (this.pbUrlInput) {
            localStorage.setItem('pocketbase_url', this.pbUrlInput);
          } else {
            localStorage.removeItem('pocketbase_url');
          }

          await this.reloadConfig();
        },

        async clearConfigOverride() {
          localStorage.removeItem('tenant_id');
          localStorage.removeItem('pocketbase_url');
          await this.reloadConfig();
        },

        // Calculate totals for dashboard
        getStats() {
          const totalMatches = this.matches.length;
          const liveMatches = this.matches.filter(m => m.status === 'Live').length;
          const finishedMatches = this.matches.filter(m => m.status === 'Finished').length;
          const predictionsMade = Object.keys(this.predictions).length;
          
          return {
            totalMatches,
            liveMatches,
            finishedMatches,
            predictionsMade
          };
        }
      }));
    </script>
  </body>
</html>

<style is:global>
  [x-cloak] { display: none !important; }
  
  @keyframes pulse {
    0%, 100% { transform: scale(1); }
    50% { transform: scale(1.05); }
  }
</style>
